# CardCompare.in — environment variables
# Copy to .env and fill in. NEVER commit .env. See BACKEND_PROMPT.md §13.

# --- Client-safe (exposed to browser via Astro PUBLIC_ prefix) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only. Must NEVER appear in a PUBLIC_ var or ship to the client. ---
# Used by Edge Functions and the import/enrich scripts only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# --- Hosting deploy hook (import script triggers one rebuild at end of run) ---
DEPLOY_HOOK_URL=
