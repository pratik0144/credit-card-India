---
/*
 * Issuer page /banks/[bank] (FRONTEND §8). Prerendered. Bank blurb + RBI-regulated
 * trust line where true (DESIGN §10.4) + full card list using the collapsed CardRow.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import CardRow from '../../components/CardRow.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getBanks, getBankBySlug, getCardsByBank, getCardDetailsByIds } from '../../lib/queries';
import { breadcrumbList } from '../../lib/seo';
import { SITE } from '../../lib/site';

export const prerender = true;
export async function getStaticPaths() {
  const banks = await getBanks();
  return banks.map((b) => ({ params: { bank: b.slug } }));
}

const { bank } = Astro.params;
const b = await getBankBySlug(bank!);
if (!b) return Astro.redirect('/404');
const rows = await getCardsByBank(bank!);
const detailMap = await getCardDetailsByIds(rows.map((r) => r.card_id));
const details = rows.map((r) => detailMap.get(r.card_id) ?? null);
const path = `/banks/${bank}`;
---
<PageLayout
  title={`${b.name} Credit Cards — Reviews & Comparison`}
  description={`Compare all ${rows.length} ${b.name} credit cards. Independent, issuer-blind reviews with real fees in ₹, reward rates, and eligibility.`}
  canonicalPath={path}
  jsonLd={[breadcrumbList([{ name: 'Home', path: '/' }, { name: 'Issuers', path: '/banks/' + bank }, { name: b.name, path }])]}
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: b.name }]} />
    <AffiliateDisclosure />
    <h1>{b.name} Credit Cards</h1>
    {b.about && <p class="lede">{b.about}</p>}
    {b.is_scheduled_commercial_bank && (
      <p class="trustline">Issued by a Scheduled Commercial Bank regulated by the Reserve Bank of India.</p>
    )}
  </div>
  <section class="container section">
    <h2>All {b.name} cards we've reviewed</h2>
    {rows.length === 0 && <p>No cards catalogued for this issuer yet.</p>}
    {rows.map((row, i) => <CardRow row={row} detail={details[i]} />)}
  </section>
  <NewsletterForm source={`bank-${bank}`} />
</PageLayout>
<style>
  .lede { font-size: var(--text-body-lg); color: var(--color-text-secondary); max-width: 62ch; }
  .trustline { font-size: var(--text-body-sm); color: var(--color-text-muted); border-left: var(--border-width-thick) solid var(--color-primary-blue); padding-left: var(--space-3); }
  .section { padding-block: var(--space-12); }
</style>
