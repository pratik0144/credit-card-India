---
/*
 * Our Team / review board (FRONTEND §8, DESIGN §6.8). Author cards with headshot
 * placeholder, title, expertise tags, highlights. Three-role trust model.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAuthors } from '../../lib/queries';
export const prerender = true;
const authors = await getAuthors();
---
<PageLayout title="Our Review Board & Editorial Team" description="The named writers, editors, and reviewers behind CardCompare.in's independent, issuer-blind card ratings.">
  <div class="container" style="padding-block: var(--space-8);">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Our Team' }]} />
    <h1>Our editorial team &amp; review board</h1>
    <p class="lede">Every rating on this site is attributed to named people. Trust is built on visible authorship, not slogans.</p>
    <div class="authors">
      {authors.map((a) => (
        <article class="author-card">
          <div class="author-card__avatar" aria-hidden="true">{a.name.split(' ').map((n) => n[0]).join('').slice(0, 2)}</div>
          <div>
            <h2><a href={`/authors/${a.slug}`}>{a.name}</a></h2>
            <p class="author-card__title">{a.title}{a.is_review_board_member ? ' · Review Board' : ''}</p>
            {a.expertise_tags?.length > 0 && (
              <ul class="author-card__tags">{a.expertise_tags.map((t) => <li>{t}</li>)}</ul>
            )}
            {a.bio && <p class="author-card__bio">{a.bio}</p>}
          </div>
        </article>
      ))}
    </div>
    {/* [PLACEHOLDER] real author headshots required before launch (DESIGN §11, §13.8). */}
    <p class="note">Headshots are initials placeholders pending real photography.</p>
  </div>
</PageLayout>
<style>
  .lede { color: var(--color-text-secondary); font-size: var(--text-body-lg); max-width: 60ch; }
  .authors { display: grid; gap: var(--space-6); margin-top: var(--space-8); }
  @media (min-width: 768px) { .authors { grid-template-columns: 1fr 1fr; } }
  .author-card { display: flex; gap: var(--space-4); padding: var(--space-6); border: var(--border-width-hairline) solid var(--color-border); border-radius: var(--radius-lg); }
  .author-card__avatar { flex: none; width: 64px; height: 64px; border-radius: var(--radius-circle); background: var(--color-primary-blue-light); color: var(--color-primary-blue); display: grid; place-items: center; font-weight: var(--weight-bold); }
  .author-card h2 { font-size: var(--text-h4); margin-bottom: var(--space-1); }
  .author-card__title { color: var(--color-text-secondary); font-size: var(--text-body-sm); margin: 0 0 var(--space-2); }
  .author-card__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); list-style: none; padding: 0; margin: 0 0 var(--space-2); }
  .author-card__tags li { font-size: var(--text-caption); background: var(--color-surface-alt); padding: var(--space-1) var(--space-2); border-radius: var(--radius-sm); }
  .author-card__bio { font-size: var(--text-body-sm); color: var(--color-text-secondary); margin: 0; }
  .note { margin-top: var(--space-8); font-size: var(--text-caption); color: var(--color-text-muted); }
</style>
