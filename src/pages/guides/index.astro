---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getArticles } from '../../lib/queries';
export const prerender = true;
const guides = await getArticles('guide');
---
<PageLayout title="Credit Card Guides — India" description="Plain-English guides to choosing, using, and getting the most from Indian credit cards.">
  <div class="container" style="padding-block: var(--space-8);">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Guides' }]} />
    <h1>Guides</h1>
    <p class="lede">Second-person, number-forward guides — no jargon, no sales pitch.</p>
    <ul class="teaser-list">
      {guides.length === 0 && <p>Guides coming soon.</p>}
      {guides.map((a) => (
        <li><a href={`/guides/${a.slug}`}><h2>{a.title}</h2><p>{a.meta_description}</p></a></li>
      ))}
    </ul>
  </div>
</PageLayout>
<style>
  .lede { color: var(--color-text-secondary); font-size: var(--text-body-lg); }
  .teaser-list { list-style: none; padding: 0; display: grid; gap: var(--space-4); margin-top: var(--space-6); }
  .teaser-list a { display: block; padding: var(--space-6); border: var(--border-width-hairline) solid var(--color-border); border-radius: var(--radius-lg); color: inherit; }
  .teaser-list a:hover { box-shadow: var(--shadow-hover); text-decoration: none; }
  .teaser-list h2 { font-size: var(--text-h4); margin-bottom: var(--space-1); }
  .teaser-list p { margin: 0; color: var(--color-text-secondary); font-size: var(--text-body-sm); }
</style>
