---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../lib/site';
export const prerender = true;
---
<PageLayout title="Terms of Use" description={`The terms governing your use of ${SITE.name}.`} noindex>
  <div class="container reading-column" style="padding-block: var(--space-8);">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Terms of Use' }]} />
    <h1>Terms of use</h1>
    {/* [NEEDS LEGAL REVIEW] — working draft only. */}
    <p><strong>[NEEDS LEGAL REVIEW]</strong> — working draft, not final legal text.</p>
    <h2>Information, not advice</h2>
    <p>{SITE.name} provides general information and comparison tools to help you evaluate credit cards. Nothing on this site is financial, tax, or legal advice, and our recommendations are not a guarantee of approval by any issuer. Always verify current fees, rates, and terms in the issuer's MITC before applying.</p>
    <h2>Estimates</h2>
    <p>Reward values, annual value estimates, and combo/recommendation outputs are heuristic estimates based on published reward rates and your inputs. Actual value varies by how you redeem points, miles, or cashback.</p>
    <h2>Third-party links</h2>
    <p>When you apply through a link, you leave our site and are subject to the issuer's own terms and privacy practices.</p>
  </div>
</PageLayout>
