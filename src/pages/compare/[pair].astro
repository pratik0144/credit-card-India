---
/*
 * Pre-generated 2-card comparison /compare/[a]-vs-[b] (FRONTEND §8, §9).
 * Prerendered for high-traffic pairs from a curated list (NOT all N×N). Both
 * orderings are generated so neither direction 404s, but the reverse ordering
 * canonical-tags the alphabetical one (SEO_PROMPT §2) so only one is indexed.
 * Framing copy (§3: 400–600 words) is derived from real card data, not stock text.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import Button from '../../components/Button.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getComparePairs, getCardDetailByFullSlug } from '../../lib/queries';
import { formatAnnualFee, formatINRCompact, formatRating, formatLounge } from '../../lib/format';
import { breadcrumbList, faqPage } from '../../lib/seo';

export const prerender = true;
export async function getStaticPaths() {
  const pairs = await getComparePairs();
  const out = [];
  for (const { a, b } of pairs) {
    // canonical order: alphabetical. Generate BOTH directions; the reverse
    // page canonical-tags the sorted one so both never compete in the index.
    const [x, y] = [a, b].sort();
    // Only generate pairs where both cards exist in the catalog (avoids a
    // prerender redirect on a curated slug that doesn't match real data).
    const [dx, dy] = await Promise.all([getCardDetailByFullSlug(x), getCardDetailByFullSlug(y)]);
    if (dx && dy) {
      out.push({ params: { pair: `${x}-vs-${y}` }, props: { a: x, b: y } });
      out.push({ params: { pair: `${y}-vs-${x}` }, props: { a: y, b: x } });
    }
  }
  return out;
}

const { a, b } = Astro.props as { a: string; b: string };
const da = await getCardDetailByFullSlug(a);
const db = await getCardDetailByFullSlug(b);
if (!da || !db) return Astro.redirect('/404');
const path = `/compare/${a}-vs-${b}`;
// Canonical is ALWAYS the alphabetical ordering (§2) — the reverse direction
// renders but points its canonical here.
const [cx, cy] = [a, b].sort();
const canonicalPath = `/compare/${cx}-vs-${cy}`;
const title = `${da.card.name} vs ${db.card.name}`;
const hrefFor = (d: typeof da) => `/cards/${d.bank.slug}/${d.card.slug.replace(new RegExp(`^${d.bank.slug}-`), '')}`;

const columns = [
  { header: da.card.name, href: hrefFor(da), image: da.card.image_url },
  { header: db.card.name, href: hrefFor(db), image: db.card.image_url },
];
const rows = [
  { label: 'Our rating', values: [formatRating(da.rating?.overall_score ?? da.card.editorial_score_5), formatRating(db.rating?.overall_score ?? db.card.editorial_score_5)] },
  { label: 'Reward rate', values: [da.card.reward_rate_general_text ?? '—', db.card.reward_rate_general_text ?? '—'] },
  { label: 'Annual fee', values: [formatAnnualFee(da.card.annual_fee_amount), formatAnnualFee(db.card.annual_fee_amount)] },
  { label: 'Forex markup', values: [da.card.forex_markup_pct != null ? `${da.card.forex_markup_pct}%` : '—', db.card.forex_markup_pct != null ? `${db.card.forex_markup_pct}%` : '—'] },
  { label: 'Domestic lounge', values: [formatLounge(da.card.lounge_domestic_visits_per_year ?? 0), formatLounge(db.card.lounge_domestic_visits_per_year ?? 0)] },
  { label: 'Min. CIBIL', values: [da.card.cibil_min ?? 'Flexible', db.card.cibil_min ?? 'Flexible'] },
];

// --- Data-derived framing copy (§3). Every sentence keys off real fields so
// no two comparison pages read identically. ---
const scoreA = da.rating?.overall_score ?? da.card.editorial_score_5;
const scoreB = db.rating?.overall_score ?? db.card.editorial_score_5;
const higherRated = scoreA != null && scoreB != null ? (scoreA === scoreB ? null : scoreA > scoreB ? da : db) : null;
const feeA = da.card.annual_fee_amount;
const feeB = db.card.annual_fee_amount;
const cheaper = feeA != null && feeB != null && feeA !== feeB ? (feeA < feeB ? da : db) : null;
const pricier = cheaper === da ? db : cheaper === db ? da : null;
const feeGap = feeA != null && feeB != null ? Math.abs(feeA - feeB) : null;
const fxA = da.card.forex_markup_pct;
const fxB = db.card.forex_markup_pct;
const betterForex = fxA != null && fxB != null && fxA !== fxB ? (fxA < fxB ? da : db) : null;
const loungeA = da.card.lounge_domestic_visits_per_year ?? 0;
const loungeB = db.card.lounge_domestic_visits_per_year ?? 0;
const betterLounge = loungeA !== loungeB ? (loungeA > loungeB ? da : db) : null;
const sameBank = da.bank.id === db.bank.id;

const faqs = [
  {
    q: `${da.card.name} or ${db.card.name} — which is better?`,
    a: higherRated
      ? `On our issuer-blind rubric, the ${higherRated.card.name} rates higher (${formatRating(higherRated === da ? scoreA : scoreB)} vs ${formatRating(higherRated === da ? scoreB : scoreA)}). But the better card for you depends on your spending pattern — the comparison table above shows where each one wins.`
      : `Our ratings put them close together, so the decision comes down to fit: compare the annual fee, reward rate, and travel benefits above against how you actually spend.`,
  },
  {
    q: `Which has the lower annual fee, ${da.card.name} or ${db.card.name}?`,
    a: cheaper
      ? `The ${cheaper.card.name} — ${formatAnnualFee(cheaper.card.annual_fee_amount)} against ${formatAnnualFee(pricier!.card.annual_fee_amount)} for the ${pricier!.card.name}${feeGap ? `, a difference of ${formatINRCompact(feeGap)} a year` : ''}. Check each card's fee-waiver spend threshold before letting the fee decide alone.`
      : `Both carry the same annual fee (${formatAnnualFee(feeA)}), so the fee is a wash — let the reward rate and benefits decide.`,
  },
  {
    q: `Can I hold both the ${da.card.name} and the ${db.card.name}?`,
    a: sameBank
      ? `Both are issued by ${da.bank.name}, and most issuers do allow multiple cards, subject to a combined credit limit. Whether it's worth it is a different question — our combo optimizer can tell you if this pairing actually covers more spend categories than either card alone.`
      : `Yes — they come from different issuers (${da.bank.name} and ${db.bank.name}), so each application is judged independently. If their reward categories complement each other, holding both can out-earn either alone; our combo optimizer will run that maths on your spending.`,
  },
];

const jsonLd = [
  breadcrumbList([{ name: 'Home', path: '/' }, { name: 'Compare', path: '/compare' }, { name: title, path: canonicalPath }]),
  faqPage(faqs),
];
---
<PageLayout
  title={`${title}: Which Card Wins?`}
  description={`${da.card.name} vs ${db.card.name} — compare rewards, fees, forex, lounge access, and eligibility to see which credit card is right for you.`}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <div class="container" style="padding-block: var(--space-8);">
    <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Compare', path: '/compare' }, { name: title }]} />
    <AffiliateDisclosure />
    <h1>{da.card.name} vs {db.card.name}</h1>
    <p class="lede">A head-to-head on the numbers that matter. Prefer to build your own? Use the <a href="/compare">interactive compare tool</a>.</p>

    <!-- Framing copy above the table (§3) -->
    <div class="reading-column framing">
      <p>
        Choosing between the <a href={hrefFor(da)}>{da.card.name}</a> from {da.bank.name} and the
        <a href={hrefFor(db)}>{db.card.name}</a> from {db.bank.name} is a common shortlist
        {sameBank ? ' — unusually, both come from the same issuer, so this is really a question of which product tier matches your spending' : ', and the two cards take genuinely different approaches to earning you value'}.
        {higherRated
          ? ` On our issuer-blind rubric the ${higherRated.card.name} comes out ahead (${formatRating(higherRated === da ? scoreA : scoreB)} vs ${formatRating(higherRated === da ? scoreB : scoreA)}), but a headline rating never settles a two-card decision on its own.`
          : ' Our editorial ratings put them close enough that the winner depends entirely on your spending profile.'}
      </p>
      <p>
        {cheaper
          ? `On cost, the ${cheaper.card.name} is the lighter commitment at ${formatAnnualFee(cheaper.card.annual_fee_amount).toLowerCase()} against ${formatAnnualFee(pricier!.card.annual_fee_amount).toLowerCase()} for the ${pricier!.card.name}${feeGap && feeGap > 0 ? ` — a gap of ${formatINRCompact(feeGap)} every year that the pricier card's extra rewards need to earn back before it breaks even` : ''}.`
          : `Neither card wins on cost — both carry ${formatAnnualFee(feeA).toLowerCase()} as the annual fee — so the comparison rests on what each returns for your spending.`}
        {betterForex
          ? ` If you spend abroad, note the forex column: the ${betterForex.card.name}'s ${betterForex === da ? fxA : fxB}% markup beats the other's ${betterForex === da ? fxB : fxA}% on every international transaction.`
          : ''}
        {betterLounge
          ? ` For airport lounge access, the ${betterLounge.card.name} is the clear pick with ${formatLounge(betterLounge === da ? loungeA : loungeB)} domestic visits a year versus ${formatLounge(betterLounge === da ? loungeB : loungeA)}.`
          : ''}
      </p>
      <p>
        The table below puts the two side by side on the numbers that decide it — reward rate, fees, forex
        markup, lounge access, and the CIBIL score each realistically requires. Figures come from our reviewed
        database; anything we could not verify against the issuer's MITC is labelled an estimate in the full
        reviews linked from each column.
      </p>
    </div>

    <ComparisonTable variant="cards" caption={title} columns={columns} rows={rows} />

    <div class="reading-column framing">
      <h2>Which one should you pick?</h2>
      <p>
        Pick the <strong>{da.card.name}</strong> if its reward structure ({da.card.reward_rate_general_text ?? 'see review'})
        matches where your money actually goes{loungeA > loungeB ? ', or if lounge access matters to you' : ''}{cheaper === da ? ', or if you want the lower fixed cost' : ''}.
        Pick the <strong>{db.card.name}</strong> if {db.card.reward_rate_general_text ? `${db.card.reward_rate_general_text.toLowerCase()} fits your spending better` : 'its earn pattern fits your spending better'}{loungeB > loungeA ? ', or if you value its stronger lounge benefit' : ''}{cheaper === db ? ', or if keeping the annual fee down is the priority' : ''}.
        And if the honest answer is "both cover different halves of my spending", that's exactly what the
        <a href="/combo-optimizer">combo optimizer</a> is for.
      </p>
      <h2>Frequently asked questions</h2>
      <dl class="faq">{faqs.map((f) => (<><dt>{f.q}</dt><dd>{f.a}</dd></>))}</dl>
    </div>

    <div class="cta">
      <Button variant="outline" href={hrefFor(da)}>Read {da.card.name} review</Button>
      <Button variant="outline" href={hrefFor(db)}>Read {db.card.name} review</Button>
    </div>
  </div>
  <NewsletterForm source={`compare-${a}-vs-${b}`} />
</PageLayout>
<style>
  .lede { font-size: var(--text-body-lg); color: var(--color-text-secondary); margin-bottom: var(--space-6); }
  .framing { margin-block: var(--space-6); }
  .framing p { color: var(--color-text-secondary); }
  .faq dt { font-weight: var(--weight-semibold); margin-top: var(--space-4); }
  .faq dd { margin: var(--space-1) 0 0; color: var(--color-text-secondary); }
  .cta { display: flex; flex-wrap: wrap; gap: var(--space-4); margin-top: var(--space-8); }
</style>
