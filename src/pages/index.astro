---
/*
 * Homepage (FRONTEND §8). Stays sparse by comparison-site standards: hero + CTA
 * into /recommend, category pill strip, 3–5 collapsed CardRows, how-it-works,
 * editorial teasers, trust block, newsletter, footer. No dense tables above the
 * fold (§3). Prerendered (§5).
 */
import PageLayout from '../layouts/PageLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CategoryPillStrip from '../components/CategoryPillStrip.astro';
import CardRow from '../components/CardRow.astro';
import Button from '../components/Button.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import AsSeenOnStrip from '../components/AsSeenOnStrip.astro';
import { SITE } from '../lib/site';
import { currentMonthYear } from '../lib/format';
import { getCardListing, getCardDetailsByIds, getArticles } from '../lib/queries';
import { organizationSchema, webSiteSchema } from '../lib/seo';

export const prerender = true;

const listing = await getCardListing();
const issuerCount = new Set(listing.map((r) => r.bank_name)).size;
const featured = listing.slice(0, 4);
const featuredMap = await getCardDetailsByIds(featured.map((r) => r.card_id));
const featuredDetails = featured.map((r) => featuredMap.get(r.card_id) ?? null);
const teasers = (await getArticles()).slice(0, 3);
const eyebrows = ['Editor’s pick', 'Best for cashback', 'Best for travel', 'Best lifetime-free'];
---
<PageLayout
  title={`${SITE.name} — Compare India's Best Credit Cards`}
  description={`${SITE.tagline}. Independent, issuer-blind reviews of 350+ Indian credit cards — compare rewards, fees, and eligibility. Updated ${currentMonthYear()}.`}
  ogType="website"
  jsonLd={[organizationSchema(), webSiteSchema()]}
>
  <!-- Hero — mesh-gradient atmospheric backdrop, hero scale ONLY -->
  <section class="hero mesh-hero">
    <div class="container">
      <p class="eyebrow">Independent · Issuer-blind · Updated {currentMonthYear()}</p>
      <h1 class="hero__title">Find the right credit card, without the sales pitch.</h1>{/* sentence-case, period-terminated (brand voice) */}
      <p class="hero__sub">
        We review India's cards the way a research desk would — numbers first, every rating attributed,
        and we tell you when a card <em>isn't</em> for you.
      </p>
      <div class="hero__cta">
        <Button variant="primary" size="lg" href="/recommend">Check my eligibility &amp; get matched</Button>
        <Button variant="outline" href="/best/all-credit-cards">Browse all cards</Button>
      </div>
      <p class="hero__trust">A soft, estimate-based match — no PAN, no credit-score impact.</p>
    </div>
  </section>

  <div class="container">
    <AffiliateDisclosure />
    <CategoryPillStrip />
  </div>

  <!-- Featured cards (collapsed rows) -->
  <section class="container section reveal">
    <h2>Top card picks this month</h2>
    <p class="section__lede">A few standouts from our latest reviews. Expand any card for the full breakdown.</p>
    {featured.map((row, i) => (
      <CardRow row={row} detail={featuredDetails[i]} eyebrow={eyebrows[i]} />
    ))}
    <Button variant="ghost" href="/best/all-credit-cards">See all card reviews →</Button>
  </section>

  <!-- How it works -->
  <section class="surface-alt">
    <div class="container section reveal">
      <h2>How it works</h2>
      <ol class="how">
        <li><span class="how__n">1</span><h3>Answer a few questions</h3><p>Tell us how you spend and what you want. Takes about a minute.</p></li>
        <li><span class="how__n">2</span><h3>Compare your matches</h3><p>See estimated annual value, fees, and eligibility side by side.</p></li>
        <li><span class="how__n">3</span><h3>Apply with confidence</h3><p>Apply on the issuer's secure site — we're transparent about our affiliate links.</p></li>
      </ol>
    </div>
  </section>

  <!-- Editorial teasers -->
  {teasers.length > 0 && (
    <section class="container section">
      <h2>Guides &amp; updates</h2>
      <div class="teasers">
        {teasers.map((a) => (
          <a class="teaser" href={`/${a.article_type === 'news' ? 'news' : 'guides'}/${a.slug}`}>
            <p class="eyebrow">{a.article_type === 'news' ? 'News / RBI Update' : 'Guide'}</p>
            <h3>{a.title}</h3>
            <p class="teaser__excerpt">{a.meta_description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Trust block -->
  <section class="surface-alt">
    <div class="container section trust">
      <h2>Why trust {SITE.name}</h2>
      <div class="trust__grid">
        {/* Counts derived from the live catalog at build time — never invented (DESIGN §6.8, §13.8). */}
        <div><strong>{listing.length}</strong><span>cards tracked across {issuerCount} issuers</span></div>
        <div><strong>Issuer-blind</strong><span>ratings — issuers can't influence rank</span></div>
        <div><strong>Every rating</strong><span>attributed to a named reviewer</span></div>
        <div><strong>Fee-change</strong><span>tracking so reviews never go stale</span></div>
      </div>
    </div>
  </section>


  <!-- Below-fold explanatory prose (SEO_PROMPT §3 — 500–700 words, prerendered).
       Kept after the product sections so it never crowds the hero. -->
  <section class="container section reading-column about-prose reveal">
    <h2>Compare credit cards in India, without the sales pitch</h2>
    <p>
      {SITE.name} exists to answer one question honestly: <strong>which credit card should you get?</strong>
      India has more than 350 actively marketed credit cards across 20+ issuers — from lifetime-free starter
      cards to super-premium metal cards with ₹12,500 annual fees — and almost every site that "compares" them
      earns more when you pick the card they push hardest. We do earn affiliate commission from some issuers
      (it's how the site stays free), but our ratings are issuer-blind: the editorial score is locked before
      anyone looks at what a card pays us, and plenty of our top-rated cards pay us nothing at all.
    </p>

    <h3>How we compare credit cards</h3>
    <p>
      Every card in our catalogue is scored on the same rubric: rewards value at realistic Indian spend levels,
      total cost of ownership (joining fee, annual fee and its waiver threshold, forex markup), welcome and
      milestone benefits, redemption flexibility, and issuer service quality. The key step is normalisation —
      we convert every reward structure, whether it's "5X points on dining" or "1.5% cashback", into an
      estimated rupee value per ₹100 spent. That's what makes an HDFC points card genuinely comparable with an
      SBI cashback card or an Axis miles card on a single axis, instead of leaving you to guess what a point
      is worth.
    </p>

    <h3>How the recommendation engine works</h3>
    <p>
      If you'd rather not read 350 reviews, the <a href="/recommend">card recommendation tool</a> asks about
      eight questions — your monthly spend by category, whether you travel, your approximate CIBIL score band,
      and the annual fee you're comfortable with — then ranks cards by the estimated annual value each would
      return on <em>your</em> spending, net of fees. It's a soft, estimate-based match: no PAN, no OTP, and no
      hard inquiry on your credit report. If you already hold a card or two, the
      <a href="/combo-optimizer">combo optimizer</a> goes a step further and finds the best 2- or 3-card
      pairing, assigning each spend category to whichever card rewards it best.
    </p>

    <h3>Who this site is for</h3>
    <p>
      First-time applicants who want a clear answer on the best credit card in India for their CIBIL score
      band; frequent flyers deciding between lounge-access travel cards; cashback maximisers weighing a flat
      2% card against category multipliers; and anyone whose issuer just devalued a reward programme and wants
      to know whether it's time to switch. Our <a href="/cibil-score">CIBIL score guide</a> explains what
      score each card realistically requires, and our <a href="/changes">card change log</a> tracks fee hikes
      and reward devaluations so a review you read today reflects the card as it exists today.
    </p>

    <h3>What we won't do</h3>
    <p>
      We won't tell you a card is "worth it" when the maths says otherwise, we won't hide the annual fee below
      the fold, and every review includes a "why you might want a different card" section — because the best
      credit card comparison in India is only useful if it's willing to say <em>no card at all</em> is
      sometimes the right answer. Figures we can't verify from an issuer's MITC are labelled as estimates, and
      every rating carries the name of the person who wrote it.
    </p>
  </section>

  <AsSeenOnStrip />
  <NewsletterForm source="homepage" />
</PageLayout>

<style>
  .hero { padding-block: var(--space-20) var(--space-16); }
  .hero__title {
    font-size: var(--text-display);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display-xl);
    max-width: 18ch;
    margin-block: var(--space-2) var(--space-4);
  }
  @media (max-width: 600px) { .hero__title { font-size: var(--text-h1); letter-spacing: var(--tracking-display-lg); } }
  .hero__sub { font-size: var(--text-body-lg); color: var(--color-text-secondary); max-width: 52ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: var(--space-4); margin-top: var(--space-6); }
  .hero__trust { margin-top: var(--space-3); font-size: var(--text-body-sm); color: var(--color-text-muted); }
  .section { padding-block: var(--space-16); }
  .section__lede { color: var(--color-text-secondary); margin-bottom: var(--space-8); max-width: 60ch; }
  .surface-alt { background: var(--color-surface-footer); }
  .how { display: grid; gap: var(--space-8); list-style: none; padding: 0; margin: 0; }
  @media (min-width: 768px) { .how { grid-template-columns: repeat(3, 1fr); } }
  .how__n { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: var(--radius-circle); background: var(--color-cta-primary); color: var(--color-on-primary); font-weight: var(--weight-medium); font-family: var(--font-mono); margin-bottom: var(--space-3); }
  .how h3 { font-size: var(--text-h4); margin-bottom: var(--space-1); }
  .how p { color: var(--color-text-secondary); font-size: var(--text-body-sm); margin: 0; }
  .teasers { display: grid; gap: var(--space-6); }
  @media (min-width: 768px) { .teasers { grid-template-columns: repeat(3, 1fr); } }
  .teaser { display: block; background: var(--color-surface); border-radius: var(--radius-md); box-shadow: var(--shadow-hairline-inset), var(--shadow-elevation-1); padding: var(--space-6); color: inherit; text-decoration: none; transition: transform var(--duration-base) var(--ease-out), box-shadow var(--duration-base) var(--ease-out); }
  .teaser:hover { transform: translateY(-2px); box-shadow: var(--shadow-hairline-inset), var(--shadow-hover); text-decoration: none; }
  .teaser h3 { font-size: var(--text-h4); margin-block: var(--space-1) var(--space-2); }
  .teaser__excerpt { color: var(--color-text-secondary); font-size: var(--text-body-sm); margin: 0; }
  .trust__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); margin-top: var(--space-4); }
  @media (min-width: 768px) { .trust__grid { grid-template-columns: repeat(4, 1fr); } }
  .trust__grid strong { display: block; font-size: var(--text-h2); letter-spacing: var(--tracking-display-md); color: var(--color-text-primary); }
  .trust__grid span { color: var(--color-text-secondary); font-size: var(--text-body-sm); }
  .trust__note { margin-top: var(--space-8); font-size: var(--text-caption); color: var(--color-text-muted); }
</style>
