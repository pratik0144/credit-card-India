---
/*
 * Marketing landing page (route `/`, SSG). Distinct from /discover — this page
 * explains what CardCompare.in is and why its ratings can be trusted, then routes
 * visitors into the tools. /discover remains the card-discovery / tool hub.
 *
 * Signature hero moment: a real "ledger specimen" — the top-rated card in the
 * catalogue, shown with its normalized ₹-per-₹100 reward value and a live
 * RatingWidget sub-score breakdown. Every number is pulled from the live catalog
 * (queries.ts) at build time, falling back to seed data — never hardcoded.
 *
 * Organization + WebSite JSON-LD lives HERE (the canonical entry Google indexes
 * for the sitelinks search box), not on /discover.
 */
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/Button.astro';
import RatingWidget from '../components/RatingWidget.astro';
import ScoreTierBadge from '../components/ScoreTierBadge.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import FeatureCard from '../components/FeatureCard.astro';
import PersonaCard from '../components/PersonaCard.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { SITE } from '../lib/site';
import { currentMonthYear, formatAnnualFee } from '../lib/format';
import { getCardListing, getCardDetailsByIds, getArticles, getCategories } from '../lib/queries';
import { organizationSchema, webSiteSchema } from '../lib/seo';

export const prerender = true;

/* ---- Live stats, sourced at build time (never hardcoded, §2) ---- */
const listing = await getCardListing();
const cardCount = listing.length;                                   // active cards (357), not total imports
const issuerCount = new Set(listing.map((r) => r.bank_name)).size;
const categoryCount = (await getCategories()).length;

/* ---- Hero specimen: the single top-rated card, with full sub-scores ---- */
const topRow = listing[0] ?? null;
const specimenMap = topRow ? await getCardDetailsByIds([topRow.card_id]) : null;
const specimen = topRow ? (specimenMap?.get(topRow.card_id) ?? null) : null;
const specimenValue = specimen?.card.base_reward_value_inr_per_100 ?? null;

/* ---- Latest guides / news preview ---- */
const teasers = (await getArticles()).slice(0, 3);
---
<PageLayout
  title={`${SITE.name} — One rating system for every credit card in India`}
  description={`We convert every bank's reward points, cashback, and miles onto a single ₹-per-₹100 scale, then rate what's left: fees, flexibility, and service. Independent, issuer-blind reviews of Indian credit cards. Updated ${currentMonthYear()}.`}
  canonicalPath="/"
  ogType="website"
  jsonLd={[organizationSchema(), webSiteSchema()]}
>
  <!-- ============================================================ Hero -->
  <section class="hero mesh-hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <p class="eyebrow">Independent · Issuer-blind · Updated {currentMonthYear()}</p>
        <h1 class="hero__title">One rating system for every credit card in India.</h1>
        <p class="hero__sub">
          We convert every bank's reward points, cashback, and miles onto a single
          <strong>₹-per-₹100-spent</strong> scale, then rate what's left — fees, flexibility, and
          service. Commercial deals never touch the ranking.
        </p>
        <div class="hero__cta">
          <Button variant="primary" size="lg" href="/recommend">Get my matches</Button>
          <Button variant="outline" size="lg" href="#methodology">See how we rate cards</Button>
        </div>
        <p class="hero__trust">No PAN. No credit-score impact. Takes about a minute.</p>
      </div>

      {specimen && (
        <aside class="specimen" aria-label="Example rating">
          <p class="specimen__eyebrow">A rating, shown in full</p>
          <div class="specimen__head">
            {specimen.card.image_url && (
              <img
                class="specimen__img"
                src={specimen.card.image_url}
                alt={`${specimen.bank.name} ${specimen.card.name}`}
                width="112" height="71" loading="eager" decoding="async"
              />
            )}
            <div class="specimen__id">
              <p class="specimen__bank">{specimen.bank.name}</p>
              <p class="specimen__name">{specimen.card.name}</p>
              {specimen.card.tier && <ScoreTierBadge tier="excellent" label={specimen.card.tier} />}
            </div>
          </div>

          <dl class="specimen__figures">
            <div>
              <dt>Normalized reward value</dt>
              <dd>{specimenValue != null ? `₹${specimenValue.toFixed(2)}` : '—'}<span> / ₹100</span></dd>
            </div>
            <div>
              <dt>Annual fee</dt>
              <dd>{formatAnnualFee(specimen.card.annual_fee_amount)}</dd>
            </div>
          </dl>

          <RatingWidget
            score={specimen.rating?.overall_score ?? null}
            subscores={specimen.rating}
            showMethodology={false}
            idSuffix="hero"
          />
          <p class="specimen__foot">Every card in the catalogue is scored on the same five axes.</p>
        </aside>
      )}
    </div>
  </section>

  <div class="container">
    <AffiliateDisclosure />
  </div>

  <!-- ==================================================== Proof / stats -->
  <section class="surface-alt">
    <div class="container section reveal">
      <dl class="stats">
        <div class="stat">
          <dt class="stat__k">{cardCount}</dt>
          <dd class="stat__v">cards tracked across {issuerCount} issuers</dd>
        </div>
        <div class="stat">
          <dt class="stat__k">6</dt>
          <dd class="stat__v">free tools — recommender, combo optimizer, calculator, compare, CIBIL hub, wallet</dd>
        </div>
        <div class="stat">
          <dt class="stat__k">{categoryCount}</dt>
          <dd class="stat__v">categories, every rating locked before any commercial deal</dd>
        </div>
        <div class="stat">
          <dt class="stat__k">Every rating</dt>
          <dd class="stat__v">attributed to a <a href="/authors">named reviewer</a></dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ====================================================== Feature grid -->
  <section class="container section reveal">
    <h2 class="section__title">Everything you need to choose — and keep choosing well</h2>
    <p class="section__lede">
      Six free tools and a full review catalogue, grouped by what you're trying to do.
    </p>

    <div class="clusters">
      <FeatureGrid eyebrow="Find your match" title="Get to a shortlist fast">
        <FeatureCard title="Smart Recommender" description="Answer 8 questions on how you spend, what you earn, and your CIBIL band. We rank cards by estimated annual value, net of fees." href="/recommend" linkLabel="Get my matches">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        </FeatureCard>
        <FeatureCard title="Combo Optimizer" description="One card rarely covers everything. We find the 2–3 card combination that earns the best rate in every spend category, without paying for overlap." href="/combo-optimizer" linkLabel="Build a combo">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="14" height="9" rx="2"/><rect x="8" y="9" width="14" height="9" rx="2"/></svg>
        </FeatureCard>
        <FeatureCard title="Best Card Calculator" description="Which card should you tap right now? Tell us the category and amount; we tell you which card in your wallet earns most for that one purchase." href="/calculator/best-card" linkLabel="Run the numbers">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M8 6h8M8 10h8M8 14h4"/></svg>
        </FeatureCard>
      </FeatureGrid>

      <FeatureGrid eyebrow="Compare and decide" title="See the maths, not a star rating">
        <FeatureCard title="Card Reviews" description="Every card rated across 5 dimensions — rewards, fees, welcome benefit, flexibility, issuer service — with the maths shown, not just a score." href="/discover" linkLabel="Browse reviews">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5z"/></svg>
        </FeatureCard>
        <FeatureCard title="Compare Tool" description="Put up to 3 cards side by side on fees, rewards, and eligibility — plus curated card-vs-card pages for the comparisons people search most." href="/compare" linkLabel="Compare cards">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M5 7h4l-2 5H3zM15 7h6l-2 5h-4z"/></svg>
        </FeatureCard>
        <FeatureCard title="CIBIL Score Hub" description="Recommendations organized by CIBIL band, with plain-language notes on what actually improves your approval odds." href="/cibil-score" linkLabel="Check by score">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14a9 9 0 0 1 18 0"/><path d="M12 14l4-3"/><circle cx="12" cy="14" r="1"/></svg>
        </FeatureCard>
      </FeatureGrid>

      <FeatureGrid eyebrow="Stay current" title="A review that's still true tomorrow">
        <FeatureCard title="Change Tracker" description="Cards change quietly — fee hikes, reward devaluations, benefit cuts. We log every one with a date, so today's review reflects today's card." href="/changes" linkLabel="See recent changes">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 4v4h4"/></svg>
        </FeatureCard>
        <FeatureCard title="My Wallet" description="A private tracker for the cards you hold — spend progress toward fee waivers, renewal dates, and a reminder before you get charged." href="/wallet" linkLabel="Track my cards">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M16 14h2"/></svg>
        </FeatureCard>
        <FeatureCard title="Guides & News" description="Plain-English guides, category roundups, and the RBI and industry news that actually affects your card." href="/guides" linkLabel="Read the guides">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5a2 2 0 0 1 2-2h9l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M14 3v5h5"/></svg>
        </FeatureCard>
      </FeatureGrid>

      <FeatureGrid eyebrow="Trust the source" title="Every rating has a name attached">
        <FeatureCard title="Author Profiles" description="Meet the editorial team and see which reviews clear the review board. Every rating is signed by the person who wrote it." href="/authors" linkLabel="Meet the team">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
        </FeatureCard>
        <FeatureCard title="Full-Text Search" description="Find any card or article in seconds, across the full catalogue and our editorial library." href="/search" linkLabel="Search everything">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        </FeatureCard>
        <FeatureCard title="Editorial Independence" description="The editorial score is locked before anyone looks at what a card pays us — and plenty of our top-rated cards pay us nothing at all." href="/editorial-guidelines" linkLabel="Our guidelines">
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 4v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V7z"/><path d="m9 12 2 2 4-4"/></svg>
        </FeatureCard>
      </FeatureGrid>
    </div>
  </section>

  <!-- ======================================================= How it works -->
  <section class="surface-alt">
    <div class="container section reveal">
      <h2 class="section__title">How it works</h2>
      <ol class="how">
        <li><span class="how__n">1</span><h3>Answer a few questions</h3><p>Tell us how you spend and what you want. Takes about a minute — no PAN, no OTP, no hard inquiry.</p></li>
        <li><span class="how__n">2</span><h3>Compare your matches</h3><p>See estimated annual value, fees, and eligibility side by side, with the maths behind every rating.</p></li>
        <li><span class="how__n">3</span><h3>Apply with confidence</h3><p>Apply on the issuer's secure site. We're transparent about our affiliate links — they never change the ranking.</p></li>
      </ol>
    </div>
  </section>

  <!-- ==================================================== Why trust (tease) -->
  <section id="methodology" class="container section reading-column reveal">
    <p class="eyebrow">Why trust {SITE.name}</p>
    <h2 class="section__title">Numbers first, then the fine print</h2>
    <p class="prose">
      Every reward structure — "5X points on dining", "1.5% cashback", "5 miles per ₹100" — gets converted
      into an estimated rupee value per ₹100 spent. That single scale is what makes an HDFC points card
      genuinely comparable with an SBI cashback card or an Axis miles card, instead of leaving you to guess
      what a point is worth.
    </p>
    <p class="prose">
      <strong>What we won't do:</strong> we won't call a card "worth it" when the maths says otherwise, we
      won't hide the annual fee below the fold, and every review names the person who wrote it. Figures we
      can't verify from an issuer's MITC are labelled as estimates.
    </p>
    <p class="prose prose__links">
      <a href="/editorial-guidelines">Read our full methodology →</a>
      <a href="/authors">Meet the editorial team →</a>
    </p>
  </section>

  <!-- ========================================================= Who it's for -->
  <section class="surface-alt">
    <div class="container section reveal">
      <h2 class="section__title">Who it's for</h2>
      <div class="personas">
        <PersonaCard label="01" name="First-time applicants" line="A clear answer on the right first card for your CIBIL band — and how to improve approval odds." />
        <PersonaCard label="02" name="Frequent flyers" line="Lounge access, miles, and forex markup weighed honestly against the annual fee." />
        <PersonaCard label="03" name="Cashback maximisers" line="Flat 2% versus category multipliers, settled on your actual spending pattern." />
        <PersonaCard label="04" name="Card switchers" line="Reassessing after a reward devaluation? See what changed, and whether it's time to move." />
      </div>
    </div>
  </section>

  <!-- ===================================================== Guides preview -->
  {teasers.length > 0 && (
    <section class="container section reveal">
      <h2 class="section__title">Guides &amp; updates</h2>
      <div class="teasers">
        {teasers.map((a) => (
          <a class="teaser hover-lift" href={`/${a.article_type === 'news' ? 'news' : 'guides'}/${a.slug}`}>
            <p class="eyebrow">{a.article_type === 'news' ? 'News / RBI Update' : 'Guide'}</p>
            <h3>{a.title}</h3>
            <p class="teaser__excerpt">{a.meta_description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <NewsletterForm source="landing" />
</PageLayout>

<style>
  /* ---- Hero ---- */
  .hero { padding-block: var(--space-20) var(--space-16); }
  .hero__grid { display: grid; gap: var(--space-12); align-items: center; }
  @media (min-width: 1024px) {
    .hero__grid { grid-template-columns: 1.1fr 0.9fr; gap: var(--space-16); }
  }
  .hero__title {
    font-size: var(--text-display);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-display-xl);
    max-width: 16ch;
    margin-block: var(--space-2) var(--space-4);
  }
  @media (max-width: 600px) {
    .hero__title { font-size: var(--text-h1); letter-spacing: var(--tracking-display-lg); }
  }
  .hero__sub { font-size: var(--text-body-lg); color: var(--color-text-secondary); max-width: 52ch; line-height: var(--leading-relaxed); }
  .hero__cta { display: flex; flex-wrap: wrap; gap: var(--space-4); margin-top: var(--space-6); }
  .hero__trust { margin-top: var(--space-3); font-size: var(--text-body-sm); color: var(--color-text-muted); }

  /* ---- Hero specimen (the ledger card) ---- */
  .specimen {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-hairline-inset), var(--shadow-elevation-3);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-4);
  }
  .specimen__eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin: 0;
  }
  .specimen__head { display: flex; gap: var(--space-4); align-items: center; }
  .specimen__img {
    width: 112px; height: auto; border-radius: var(--radius-sm);
    box-shadow: var(--shadow-elevation-1); flex: none;
  }
  .specimen__id { display: grid; gap: var(--space-1); }
  .specimen__bank { font-size: var(--text-body-sm); color: var(--color-text-secondary); margin: 0; }
  .specimen__name { font-size: var(--text-h4); font-weight: var(--weight-semibold); color: var(--color-text-primary); margin: 0; }
  .specimen__figures {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4);
    margin: 0; padding-block: var(--space-4);
    border-block: var(--border-width-hairline) solid var(--color-border);
  }
  .specimen__figures dt { font-size: var(--text-caption); color: var(--color-text-muted); margin-bottom: var(--space-1); }
  .specimen__figures dd {
    margin: 0; font-size: var(--text-h3); font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-display-sm); color: var(--color-text-primary);
    font-family: var(--font-mono);
  }
  .specimen__figures dd span { font-size: var(--text-body-sm); font-weight: var(--weight-regular); color: var(--color-text-muted); font-family: var(--font-primary); }
  .specimen__foot { font-size: var(--text-caption); color: var(--color-text-muted); margin: 0; }

  /* ---- Shared section rhythm ---- */
  .section { padding-block: var(--space-16); }
  .surface-alt { background: var(--color-surface-footer); }
  .section__title { font-size: var(--text-h2); letter-spacing: var(--tracking-display-md); }
  .section__lede { color: var(--color-text-secondary); margin-block: var(--space-2) var(--space-8); max-width: 60ch; }

  /* ---- Stats strip ---- */
  .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); margin: 0; }
  @media (min-width: 768px) { .stats { grid-template-columns: repeat(4, 1fr); } }
  .stat { display: grid; gap: var(--space-1); align-content: start; }
  .stat__k {
    font-size: var(--text-h2); font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-display-md); color: var(--color-text-primary);
  }
  .stat__v { font-size: var(--text-body-sm); color: var(--color-text-secondary); line-height: var(--leading-normal); }

  /* ---- Feature clusters ---- */
  .clusters { display: grid; gap: var(--space-12); }

  /* ---- How it works ---- */
  .how { display: grid; gap: var(--space-8); list-style: none; padding: 0; margin: var(--space-8) 0 0; }
  @media (min-width: 768px) { .how { grid-template-columns: repeat(3, 1fr); } }
  .how__n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: var(--radius-circle);
    background: var(--color-cta-primary); color: var(--color-on-primary);
    font-weight: var(--weight-medium); font-family: var(--font-mono); margin-bottom: var(--space-3);
  }
  .how h3 { font-size: var(--text-h4); margin-bottom: var(--space-1); }
  .how p { color: var(--color-text-secondary); font-size: var(--text-body-sm); margin: 0; line-height: var(--leading-normal); }

  /* ---- Methodology tease ---- */
  .prose { color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-block: var(--space-4); }
  .prose__links { display: flex; flex-wrap: wrap; gap: var(--space-6); }
  .prose__links a { font-weight: var(--weight-medium); }

  /* ---- Personas ---- */
  .personas { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-8); }
  @media (min-width: 600px) { .personas { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .personas { grid-template-columns: repeat(4, 1fr); } }

  /* ---- Teasers ---- */
  .teasers { display: grid; gap: var(--space-6); margin-top: var(--space-8); }
  @media (min-width: 768px) { .teasers { grid-template-columns: repeat(3, 1fr); } }
  .teaser {
    display: block; background: var(--color-surface); border-radius: var(--radius-md);
    box-shadow: var(--shadow-hairline-inset), var(--shadow-elevation-1);
    padding: var(--space-6); color: inherit; text-decoration: none;
  }
  .teaser:hover { text-decoration: none; }
  .teaser h3 { font-size: var(--text-h4); margin-block: var(--space-1) var(--space-2); }
  .teaser__excerpt { color: var(--color-text-secondary); font-size: var(--text-body-sm); margin: 0; }
</style>
