---
/*
 * FeatureCard — one feature entry in a landing-page cluster.
 * Icon is an inline SVG passed via the `icon` slot (brand blue + neutral,
 * no external images). Zero JS, tokens only.
 */
export interface Props {
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
}
const { title, description, href, linkLabel } = Astro.props;
---
<div class="fc">
  <div class="fc__icon" aria-hidden="true">
    <slot name="icon" />
  </div>
  <h3 class="fc__title">{title}</h3>
  <p class="fc__desc">{description}</p>
  {href && (
    <a class="fc__link" href={href}>{linkLabel ?? 'Learn more'} →</a>
  )}
</div>

<style>
  .fc {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-hairline-inset), var(--shadow-elevation-1);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .fc__icon {
    width: 32px;
    height: 32px;
    color: var(--color-primary-blue);
    margin-bottom: var(--space-1);
    flex-shrink: 0;
  }
  .fc__icon svg { width: 100%; height: 100%; }
  .fc__title {
    font-size: var(--text-h4);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    margin: 0;
  }
  .fc__desc {
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0;
    flex: 1;
  }
  .fc__link {
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary-blue);
    text-decoration: none;
    margin-top: var(--space-1);
  }
  .fc__link:hover { text-decoration: underline; }
</style>
