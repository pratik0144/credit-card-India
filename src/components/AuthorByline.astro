---
/*
 * AuthorByline (DESIGN §6.8, §11). Three-role byline (Written / Edited /
 * Reviewed) + Updated date. Names link to author bios. NEVER collapses to an
 * anonymous "Staff" credit — the three-role structure is a deliberate trust signal.
 */
import type { Author } from '../lib/database.types';
export interface Props {
  writtenBy: Author[];
  editedBy?: Author | null;
  reviewedBy?: Author | null;
  updated?: string | null;
}
const { writtenBy, editedBy = null, reviewedBy = null, updated = null } = Astro.props;
const fmtDate = (d: string | null) =>
  d ? new Date(d).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : null;
const link = (a: Author) => `/authors/${a.slug}`;
---
<div class="byline">
  {writtenBy.length > 0 && (
    <span class="byline__part">
      <span class="byline__role">Written by</span>{' '}
      {writtenBy.map((a, i) => (
        <>{i > 0 && ', '}<a href={link(a)}>{a.name}</a></>
      ))}
    </span>
  )}
  {editedBy && (
    <span class="byline__part">
      <span class="byline__role">Edited by</span> <a href={link(editedBy)}>{editedBy.name}</a>
    </span>
  )}
  {reviewedBy && (
    <span class="byline__part">
      <span class="byline__role">Reviewed by</span> <a href={link(reviewedBy)}>{reviewedBy.name}</a>
    </span>
  )}
  {updated && (
    <span class="byline__part byline__updated">
      <span class="byline__role">Updated</span> <time datetime={updated}>{fmtDate(updated)}</time>
    </span>
  )}
</div>
<style>
  .byline {
    display: flex; flex-wrap: wrap; gap: var(--space-1) var(--space-3);
    font-size: var(--text-body-sm); color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }
  .byline__part:not(:last-child)::after {
    content: "·"; color: var(--color-border-strong); margin-left: var(--space-3);
  }
  .byline__role { color: var(--color-text-muted); }
  .byline a { font-weight: var(--weight-medium); }
</style>
